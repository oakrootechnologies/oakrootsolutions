# ──────────────────────────────────────────────────────────
# Oakroot Solutions — Email Service Configuration
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────

# ── SMTP Provider Settings ───────────────────────────────
# For Gmail: host=smtp.gmail.com, port=587, secure=false
# For Outlook/Microsoft 365: host=smtp.office365.com, port=587
# For Zoho Mail: host=smtp.zoho.in, port=587
# For Custom cPanel hosting: host=mail.yourdomain.com, port=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ── SMTP Credentials ─────────────────────────────────────
# The email address that sends all outgoing mail
# For Gmail: enable "App Passwords" in your Google account
SMTP_USER=hello@oakrootsolutions.com
SMTP_PASS=your_app_password_here

# ── Internal Operations Alert Destination ────────────────
# Where the internal "New Lead" alert email is delivered
OPS_ALERT_EMAIL=hello@oakrootsolutions.com
